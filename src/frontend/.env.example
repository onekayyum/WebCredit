# ─── API base URL ───────────────────────────────────────────────
# IMPORTANT: For mobile / Capacitor builds this MUST be an absolute
# URL because the WebView has no same-origin server.
#
# Local development (web):
#   VITE_API_URL=http://localhost:3001
#
# Production (your server IP or domain):
#   VITE_API_URL=http://128.85.36.93:4000
#   VITE_API_URL=https://memelith.fun
#
# Web builds served by the same backend (leave empty):
#   VITE_API_URL=
#
# Mobile builds (Android / iOS) — use your server's reachable address:
#   VITE_API_URL=https://memelith.fun
# ────────────────────────────────────────────────────────────────
VITE_API_URL=
