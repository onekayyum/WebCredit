{
  "name": "webcredit",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "src/frontend",
    "backend-node"
  ],
  "scripts": {
    "start": "concurrently \"npm run start --workspace backend-node\" \"npm run dev --workspace src/frontend\"",
    "build": "npm run build --workspace src/frontend",
    "typecheck": "npm run typecheck --workspace src/frontend"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  },
  "devDependencies": {
    "sharp": "^0.34.4"
  }
}
